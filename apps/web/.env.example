# Copy to `.env` and fill in real values (never commit `.env`).
#   cp .env.example .env
#
# Neon (https://neon.tech): Project → Branches → connect → use the
# **pooled** connection string for serverless / Vercel (`-pooler` host).
# Always include sslmode=require.

# PostgreSQL connection (Neon)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Optional: set for local scripts (Next.js sets this automatically in dev)
# NODE_ENV=development
